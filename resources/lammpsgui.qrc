  <!-- Minimal QIcon theme so QIcon::fromTheme() resolves the standard
       text-edit context-menu action icons (undo/redo/cut/copy/paste/delete/
       select-all) to our own icons instead of the desktop theme.  The icons
       are aliased from the flat set above so there is only one copy of each. -->
  <qresource prefix="/icons/lammpsgui">
    <file alias="index.theme">icons/lammpsgui/index.theme</file>
    <file alias="scalable/actions/edit-undo.svg">icons/edit-undo.svg</file>
    <file alias="scalable/actions/edit-redo.svg">icons/edit-redo.svg</file>
    <file alias="scalable/actions/edit-cut.svg">icons/edit-cut.svg</file>
    <file alias="scalable/actions/edit-copy.svg">icons/edit-copy.svg</file>
    <file alias="scalable/actions/edit-paste.svg">icons/edit-paste.svg</file>
    <file alias="scalable/actions/edit-delete.svg">icons/edit-delete.svg</file>
    <file alias="scalable/actions/edit-select-all.svg">icons/edit-select-all.svg</file>
  </qresource>
</RCC>
